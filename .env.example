# API
NODE_ENV=development
API_PORT=4000
MONGO_URI=mongodb://mongo:27017/ssdcloud
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
CORS_ORIGIN=http://localhost:5173
# Set to 1 when API is behind a single reverse proxy (e.g., Caddy/Nginx).
TRUST_PROXY=0
UPLOAD_PRICE_PER_MB=0.5
UPLOAD_MAX_MB=100
MULTIPART_PART_SIZE_MB=100
DOWNLOAD_LINK_DEFAULT_TTL_SECONDS=21600
DOWNLOAD_LINK_MIN_TTL_SECONDS=60
DOWNLOAD_LINK_MAX_TTL_SECONDS=604800

# Cloudflare R2 (S3-compatible)
# Format: https://<account_id>.r2.cloudflarestorage.com
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_REGION=us-east-1
S3_BUCKET=ssdcloud-files
S3_ACCESS_KEY=your-r2-access-key-id
S3_SECRET_KEY=your-r2-secret-access-key
S3_FORCE_PATH_STYLE=false

# WEB
VITE_API_BASE_URL=http://localhost:4000
